{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Petro Graphs",
  "version": "0.1.0",
  "identifier": "edu.vanderbilt.petro-graphs",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Petro Graphs",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Science",
    "copyright": "© 2025 Marvin Alejandro Lopez Acevedo",
    "longDescription": "Petro Graphs is a desktop application for compositing, annotating, and exporting geological photomicrograph figures. Purpose-built for cross-polarized light (XPL/PPL) thin section photography.",
    "shortDescription": "Geological thin-section figure editor",
    "publisher": "Marvin Alejandro Lopez Acevedo",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English-US"],
        "displayLanguageSelector": false
      },
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
